# Server Configuration
PORT=3000

# Path to the SQLite database that maps session ids to their Hive-partitioned
# S3 key prefix. In Kubernetes this lives on a PersistentVolumeClaim.
DB_PATH=transcripts.db

# Directory of built frontend static files served on non-/api routes
# (single-workload mode). Leave unset to serve the API only, e.g. when using
# the Vite dev server for the frontend.
# STATIC_DIR=../frontend/dist

# Lifetime of issued presigned upload URLs, in seconds (default 900 = 15m).
# UPLOAD_URL_TTL_SECONDS=900

# Lifetime of issued presigned download URLs, in seconds (default 300 = 5m).
# Kept short: the browser fetches the transcript files immediately after
# receiving the manifest from GET /api/transcript/session/{id}.
# DOWNLOAD_URL_TTL_SECONDS=300

# AWS S3 Configuration
AWS_REGION=us-east-1
S3_BUCKET=claude-transcripts

# Optional: S3 key prefix applied when reading transcripts.
# Use this when transcripts are stored under a sub-path within the bucket.
# Example: tenants/acme/transcripts/
# S3_PREFIX=

# Optional: Assume an IAM role before reading from S3. When AWS_ASSUME_ROLE_ARN
# is set, the S3 client uses temporary credentials obtained via STS AssumeRole
# (refreshed automatically). Leave unset to use the default credential chain.
# AWS_ASSUME_ROLE_ARN=arn:aws:iam::123456789012:role/claude-transcript-reader
# AWS_ASSUME_ROLE_SESSION_NAME=claude-transcript-viewer
# AWS_ASSUME_ROLE_EXTERNAL_ID=
# AWS_ASSUME_ROLE_DURATION_SECONDS=3600

# S3-compatible endpoint for local development (e.g. MinIO on :9000)
# Start MinIO locally with:
#   docker run -d --name minio -p 9000:9000 \
#     -e MINIO_ROOT_USER=minioadmin -e MINIO_ROOT_PASSWORD=minioadmin \
#     minio/minio:latest server /data
# AWS_ENDPOINT_URL=http://localhost:9000

# Optional: endpoint used only when presigning URLs handed to browsers.
# Set this when the backend reaches S3 through an internal endpoint that
# browsers cannot resolve (e.g. backend uses http://localstack:4566 inside a
# cluster while the browser reaches it via a port-forward on localhost).
# AWS_PUBLIC_ENDPOINT_URL=http://localhost:4566
