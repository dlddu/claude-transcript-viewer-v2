# Backend Configuration
PORT=3000
NODE_ENV=development

# Path to the SQLite database mapping session IDs to S3 keys (parent dir is
# created automatically; backed by a PersistentVolume at /data in Kubernetes).
SQLITE_PATH=./data/transcripts.db

# AWS S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=claude-transcripts

# Optional: S3 key prefix applied when reading transcripts.
# Use this when transcripts are stored under a sub-path within the bucket.
# Example: tenants/acme/transcripts/
# S3_PREFIX=

# Optional: Assume an IAM role before reading from S3. When AWS_ASSUME_ROLE_ARN
# is set, the S3 client uses temporary credentials obtained via STS AssumeRole
# (refreshed automatically). Leave unset to use the default credential chain.
# AWS_ASSUME_ROLE_ARN=arn:aws:iam::123456789012:role/claude-transcript-reader
# AWS_ASSUME_ROLE_SESSION_NAME=claude-transcript-viewer
# AWS_ASSUME_ROLE_EXTERNAL_ID=
# AWS_ASSUME_ROLE_DURATION_SECONDS=3600

# S3-compatible endpoint for local development (e.g. MinIO)
# Start MinIO locally with:
#   docker run -d --name minio -p 9000:9000 \
#     -e MINIO_ROOT_USER=minioadmin -e MINIO_ROOT_PASSWORD=minioadmin \
#     minio/minio:latest server /data
AWS_ENDPOINT_URL=http://localhost:9000

# Frontend Configuration
VITE_API_URL=http://localhost:3000/api
