# API Configuration
#
# VITE_API_URL is optional. When unset (default), the app calls the API on the
# same origin that serves it — the Go backend in production, or the Vite dev
# proxy (/api -> http://localhost:3000) during `pnpm dev`.
# Set it only to point the frontend at a different API origin.
# VITE_API_URL=http://localhost:3000
